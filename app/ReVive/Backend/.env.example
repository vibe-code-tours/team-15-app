# Local PostgreSQL example. In production, use the complete Neon URL, including
# its SSL query parameters.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/revive_db
SECRET_KEY="replace-with-a-long-random-secret"
CORS_ORIGINS=["http://localhost:3000"]

